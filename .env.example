# ═════════════════════════════════════════════════════════════════════════════
# Handcraft Store — Environment Variables
#
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values:   nano .env
# 3. Protect it:       chmod 600 .env
# 4. Start the stack:  docker compose up -d
#
# The container automatically seeds the database and creates the admin account
# on first start — no manual scripts required.
#
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT — Dollar signs in values
# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose treats $ as the start of a variable substitution. If any
# value (e.g. a password) contains a literal $ you MUST escape it as $$.
#
#   Wrong:   ADMIN_PASSWORD=my$ecret       ← Compose strips $ecret
#   Correct: ADMIN_PASSWORD=my$$ecret      ← Container receives my$ecret
#
# The hex SESSION_SECRET generated with the command below will never contain $
# so no escaping is needed for that value.
# ═════════════════════════════════════════════════════════════════════════════


# ── Docker image ──────────────────────────────────────────────────────────────
# The image to pull from Docker Hub.
# Replace with your Docker Hub username and desired tag.
DOCKER_IMAGE=yourdockerhubuser/handcraft-store:latest


# ── Database ──────────────────────────────────────────────────────────────────
# Connection string for your existing MongoDB container.
#
# If MongoDB is on the SAME Docker network (recommended):
#   Use the MongoDB container name as the hostname.
#   MONGODB_URI=mongodb://my_mongo_container:27017/my_store
#
# If MongoDB is on a DIFFERENT network or host:
#   Use the server's IP address.
#   MONGODB_URI=mongodb://192.168.1.100:27017/my_store
#
# With authentication:
#   MONGODB_URI=mongodb://username:password@192.168.1.100:27017/my_store
#
# Unraid tip: Check your MongoDB container's name in the Docker tab.
#   The database name (my_store) will be created automatically.
MONGODB_URI=mongodb://<your-mongo-host>:27017/my_store


# ── Session secret ────────────────────────────────────────────────────────────
# REQUIRED. Must be a long, random string (64+ characters).
# Used to sign session cookies — keep this private.
#
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# Or without Node installed locally:
#   docker run --rm node:18-alpine node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING


# ── Stripe payments ───────────────────────────────────────────────────────────
# Get your keys from https://dashboard.stripe.com/apikeys
# Use live keys (sk_live_ / pk_live_) for production.
# Use test keys (sk_test_ / pk_test_) for testing.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook signing secret.
# In Stripe Dashboard → Developers → Webhooks, create an endpoint:
#   URL:    https://yourdomain.com/webhooks/stripe
#   Events: checkout.session.completed, payment_intent.payment_failed
# Then copy the Signing secret here.
STRIPE_WEBHOOK_SECRET=whsec_...


# ── Site ──────────────────────────────────────────────────────────────────────
# Your store's public URL — used for Stripe redirects, emails, and the sitemap.
# Must be the full URL with protocol, no trailing slash.
# Set this to your domain BEFORE starting, even if using a local IP for now.
#   Examples:
#     BASE_URL=https://shop.yourdomain.com     ← after setting up SSL
#     BASE_URL=http://192.168.1.100:5001       ← for initial local testing
BASE_URL=https://yourdomain.com

# Your store's display name — shown in browser tabs, emails, and the admin panel.
SITE_NAME=My Store


# ── Admin account ─────────────────────────────────────────────────────────────
# These credentials are used to create the admin account automatically on first
# start. Change them to your real email and a strong password BEFORE starting.
# If the admin account already exists these values are ignored on restart.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD


# ── Server port ───────────────────────────────────────────────────────────────
# Internal Node.js port inside the container. Do NOT change this.
PORT=5001
NODE_ENV=production


# ── App host port ─────────────────────────────────────────────────────────────
# The port the app exposes on your HOST machine.
# Point Nginx Proxy Manager at this port to reach the store.
#
# Unraid users: This is the port you enter in the "Host Port" field when
#   adding the container, or set as a Template Variable in Compose Manager.
#
# Examples:
#   APP_PORT=5001    → access at http://<server-ip>:5001
#   APP_PORT=3001    → use if 5001 is already taken on your host
APP_PORT=5001


# ── Persistent data paths ─────────────────────────────────────────────────────
# APPDATA_PATH is the base directory on your HOST where uploads and logs are
# stored. This directory is mounted into the container as a volume so your
# data survives container restarts and image updates.
#
# The container pre-creates all required subdirectories inside the image, so
# you do NOT need to create them manually.
#
# ── Unraid setup ─────────────────────────────────────────────────────────────
# In Unraid with Docker Compose Manager, set this to your appdata share:
#   APPDATA_PATH=/mnt/user/appdata/handcraft-store
#
# If using the Unraid GUI (Docker tab) instead of Compose Manager, add these
# paths as individual Volume mappings in the container template:
#   Container path: /app/uploads  →  Host path: /mnt/user/appdata/handcraft-store/uploads
#   Container path: /app/logs     →  Host path: /mnt/user/appdata/handcraft-store/logs
#
# ── Linux / VPS setup ────────────────────────────────────────────────────────
#   APPDATA_PATH=/opt/handcraft-store
#
# ── Windows / local testing ──────────────────────────────────────────────────
#   APPDATA_PATH=C:/handcraft-store-data
APPDATA_PATH=/mnt/user/appdata/handcraft-store


# ── File uploads ─────────────────────────────────────────────────────────────
# Directory inside the container where uploads are stored.
# Do NOT change UPLOAD_DIR — it must match the volume mount above.
UPLOAD_DIR=./uploads
# Maximum upload file size in bytes. Default is 10 MB.
MAX_FILE_SIZE=10485760


# ── Backup and restore scripts (optional) ────────────────────────────────────
# Used only by scripts/backup.sh and scripts/restore.sh.
# Set to the name of your MongoDB Docker container and the database name.
MONGO_CONTAINER=my_mongo
DB_NAME=my_store


# ── Email (optional — log-only stub by default) ───────────────────────────────
# Out of the box the store logs emails to the console but does not send them.
# To enable real email delivery, update src/services/emailService.js with your
# chosen provider and uncomment the relevant variables below.
#
# Option A — SMTP (Gmail, Mailgun, Postmark, etc.)
#   Requires: npm install nodemailer  (add to package.json and rebuild image)
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@yourdomain.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=hello@yourdomain.com
#
# Option B — SendGrid
#   Requires: npm install @sendgrid/mail  (add to package.json and rebuild image)
# SENDGRID_API_KEY=SG...
# EMAIL_FROM=hello@yourdomain.com
