<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= heading %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background: #FDFAF6;
      color: #2C1810;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
    }
    .maintenance-icon { font-size: 3rem; margin-bottom: 1.5rem; opacity: 0.4; }
    .maintenance-heading {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 1rem;
      color: #2C1810;
    }
    .maintenance-message {
      font-size: 1.1rem;
      color: #6B5A4E;
      max-width: 480px;
      line-height: 1.7;
    }
    .maintenance-brand {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1rem;
      color: #A0522D;
      margin-top: 3rem;
      opacity: 0.7;
    }
    @media (max-width: 576px) {
      .maintenance-heading { font-size: 1.75rem; }
    }
  </style>
</head>
<body>
  <div class="maintenance-icon">✦</div>
  <h1 class="maintenance-heading"><%= heading %></h1>
  <p class="maintenance-message"><%= message %></p>
  <p class="maintenance-brand"><%= typeof siteName !== 'undefined' ? siteName : '' %></p>
</body>
</html>
