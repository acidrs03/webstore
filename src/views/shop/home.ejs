<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<!-- Hero Section -->
<% if (hero.heroImage) { %>
<section class="hero-section--image">
  <img src="<%= hero.heroImage %>" alt="Hero" class="hero-section--img">
  <div class="hero-section--text">
    <div class="container">
      <h1 class="hero-title display-4 fw-bold mb-3"><%= hero.heroTitle || hero.title || 'Handcrafted with Heart' %></h1>
      <p class="hero-subtitle lead mb-4"><%= hero.subtitle || 'Custom laser engraved and personalized items made just for you.' %></p>
      <a href="<%= hero.ctaUrl || '/shop' %>" class="btn btn-primary-custom btn-lg px-5">
        <%= hero.ctaText || 'Shop Now' %>
      </a>
    </div>
  </div>
</section>
<% } else { %>
<section class="hero-section">
  <div class="container text-center py-5">
    <h1 class="hero-title display-4 fw-bold mb-3"><%= hero.heroTitle || hero.title || 'Handcrafted with Heart' %></h1>
    <p class="hero-subtitle lead mb-4"><%= hero.subtitle || 'Custom laser engraved and personalized items made just for you.' %></p>
    <a href="<%= hero.ctaUrl || '/shop' %>" class="btn btn-primary-custom btn-lg px-5">
      <%= hero.ctaText || 'Shop Now' %>
    </a>
  </div>
</section>
<% } %>

<!-- Featured Products -->
<% if (featuredProducts && featuredProducts.length > 0) { %>
<section class="py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="section-heading">Featured Items</h2>
      <a href="/shop" class="btn btn-outline-secondary btn-sm">View All &rarr;</a>
    </div>
    <div class="row g-4">
      <% featuredProducts.forEach(function(product) { %>
      <div class="col-6 col-md-4 col-lg-3">
        <div class="product-card card h-100 border-0 shadow-sm">
          <a href="/shop/<%= product.slug %>" class="product-card-img-link">
            <div class="product-img-wrapper">
              <% if (product.images && product.images[0]) { %>
                <img src="<%= product.images[0] %>" alt="<%= product.title %>" class="product-img card-img-top">
              <% } else { %>
                <div class="product-img-placeholder d-flex align-items-center justify-content-center bg-light">
                  <span class="text-muted">No Image</span>
                </div>
              <% } %>
            </div>
          </a>
          <div class="card-body d-flex flex-column">
            <h6 class="card-title mb-1"><a href="/shop/<%= product.slug %>" class="text-dark text-decoration-none"><%= product.title %></a></h6>
            <div class="mt-auto pt-2">
              <% if (product.compareAtPrice && product.compareAtPrice > product.price) { %>
                <span class="text-danger fw-semibold">$<%= (product.price / 100).toFixed(2) %></span>
                <span class="text-muted text-decoration-line-through small ms-1">$<%= (product.compareAtPrice / 100).toFixed(2) %></span>
              <% } else { %>
                <span class="fw-semibold text-dark">$<%= (product.price / 100).toFixed(2) %></span>
              <% } %>
            </div>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- Categories -->
<% if (categories && categories.length > 0) { %>
<section class="py-5 bg-light-warm">
  <div class="container">
    <h2 class="section-heading text-center mb-4">Shop by Category</h2>
    <div class="row g-4 justify-content-center">
      <% categories.forEach(function(cat) { %>
      <div class="col-6 col-md-4 col-lg-3">
        <a href="/shop?category=<%= cat.slug %>" class="text-decoration-none">
          <div class="category-card card border-0 shadow-sm text-center h-100">
            <div class="category-img-wrapper">
              <% if (cat.image) { %>
                <img src="<%= cat.image %>" alt="<%= cat.name %>" class="category-img">
              <% } else { %>
                <div class="category-img-placeholder bg-warm d-flex align-items-center justify-content-center">
                  <span class="display-6">✦</span>
                </div>
              <% } %>
            </div>
            <div class="card-body">
              <h6 class="card-title fw-semibold text-dark mb-1"><%= cat.name %></h6>
              <% if (cat.description) { %>
                <p class="card-text small text-muted"><%= cat.description.substring(0, 60) %><%= cat.description.length > 60 ? '…' : '' %></p>
              <% } %>
            </div>
          </div>
        </a>
      </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- Value Props -->
<section class="py-5">
  <div class="container">
    <div class="row g-4 text-center">
      <div class="col-md-4">
        <div class="p-3">
          <div class="display-5 mb-3">✦</div>
          <h5>Handcrafted Quality</h5>
          <p class="text-muted small">Every item is made with care and attention to detail.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="p-3">
          <div class="display-5 mb-3">✉</div>
          <h5>Personalized Just for You</h5>
          <p class="text-muted small">Custom text, names, and designs on any item.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="p-3">
          <div class="display-5 mb-3">⬡</div>
          <h5>Custom Orders Welcome</h5>
          <p class="text-muted small">Have a special idea? We'd love to bring it to life.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
</body>
</html>
