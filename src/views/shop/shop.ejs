<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<div class="container py-4">
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/">Home</a></li>
      <li class="breadcrumb-item active">
        <%= activeCategory ? activeCategory.name : 'Shop' %>
      </li>
    </ol>
  </nav>

  <div class="row g-4">
    <!-- Sidebar -->
    <div class="col-lg-3">
      <div class="sticky-sidebar">
        <!-- Sort -->
        <form method="GET" action="/shop" class="mb-4">
          <% if (activeCategory) { %>
            <input type="hidden" name="category" value="<%= activeCategory.slug %>">
          <% } %>
          <label class="form-label fw-semibold small text-uppercase text-muted">Sort By</label>
          <select name="sort" class="form-select form-select-sm" onchange="this.form.submit()">
            <option value="" <%= !filters.sort ? 'selected' : '' %>>Newest</option>
            <option value="price-asc" <%= filters.sort === 'price-asc' ? 'selected' : '' %>>Price: Low to High</option>
            <option value="price-desc" <%= filters.sort === 'price-desc' ? 'selected' : '' %>>Price: High to Low</option>
            <option value="featured" <%= filters.sort === 'featured' ? 'selected' : '' %>>Featured</option>
          </select>
        </form>

        <!-- Categories -->
        <h6 class="fw-semibold small text-uppercase text-muted mb-2">Categories</h6>
        <ul class="list-unstyled sidebar-cats">
          <li>
            <a href="/shop" class="sidebar-cat-link <%= !activeCategory ? 'active' : '' %>">All Products</a>
          </li>
          <% categories.forEach(function(cat) { %>
          <li>
            <a href="/shop?category=<%= cat.slug %>"
               class="sidebar-cat-link <%= activeCategory && activeCategory.slug === cat.slug ? 'active' : '' %>">
              <%= cat.name %>
            </a>
          </li>
          <% }); %>
        </ul>
      </div>
    </div>

    <!-- Products Grid -->
    <div class="col-lg-9">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0"><%= activeCategory ? activeCategory.name : 'All Products' %></h1>
        <span class="text-muted small"><%= pagination.totalItems %> item<%= pagination.totalItems !== 1 ? 's' : '' %></span>
      </div>

      <% if (products && products.length > 0) { %>
      <div class="row g-4">
        <% products.forEach(function(product) { %>
        <div class="col-6 col-md-4">
          <div class="product-card card h-100 border-0 shadow-sm">
            <a href="/shop/<%= product.slug %>" class="product-card-img-link">
              <div class="product-img-wrapper">
                <% if (product.images && product.images[0]) { %>
                  <img src="<%= product.images[0] %>" alt="<%= product.title %>" class="product-img card-img-top">
                <% } else { %>
                  <div class="product-img-placeholder d-flex align-items-center justify-content-center bg-light">
                    <span class="text-muted small">No Image</span>
                  </div>
                <% } %>
              </div>
            </a>
            <div class="card-body d-flex flex-column">
              <h6 class="card-title mb-1">
                <a href="/shop/<%= product.slug %>" class="text-dark text-decoration-none"><%= product.title %></a>
              </h6>
              <% if (product.shortDescription) { %>
                <p class="card-text small text-muted mb-2"><%= product.shortDescription.substring(0, 80) %></p>
              <% } %>
              <div class="mt-auto d-flex justify-content-between align-items-center">
                <div>
                  <% if (product.compareAtPrice && product.compareAtPrice > product.price) { %>
                    <span class="text-danger fw-semibold">$<%= (product.price / 100).toFixed(2) %></span>
                    <span class="text-muted text-decoration-line-through small ms-1">$<%= (product.compareAtPrice / 100).toFixed(2) %></span>
                  <% } else { %>
                    <span class="fw-semibold">$<%= (product.price / 100).toFixed(2) %></span>
                  <% } %>
                </div>
                <a href="/shop/<%= product.slug %>" class="btn btn-sm btn-outline-primary-custom">View</a>
              </div>
            </div>
          </div>
        </div>
        <% }); %>
      </div>

      <!-- Pagination -->
      <% if (pagination.totalPages > 1) { %>
      <nav class="mt-4" aria-label="Product pagination">
        <ul class="pagination justify-content-center">
          <% if (pagination.hasPrev) { %>
            <li class="page-item">
              <a class="page-link" href="?page=<%= pagination.prevPage %><%= filters.sort ? '&sort=' + filters.sort : '' %><%= activeCategory ? '&category=' + activeCategory.slug : '' %>">Previous</a>
            </li>
          <% } %>
          <% for (let i = 1; i <= pagination.totalPages; i++) { %>
            <li class="page-item <%= pagination.currentPage === i ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %><%= filters.sort ? '&sort=' + filters.sort : '' %><%= activeCategory ? '&category=' + activeCategory.slug : '' %>"><%= i %></a>
            </li>
          <% } %>
          <% if (pagination.hasNext) { %>
            <li class="page-item">
              <a class="page-link" href="?page=<%= pagination.nextPage %><%= filters.sort ? '&sort=' + filters.sort : '' %><%= activeCategory ? '&category=' + activeCategory.slug : '' %>">Next</a>
            </li>
          <% } %>
        </ul>
      </nav>
      <% } %>

      <% } else { %>
      <div class="text-center py-5">
        <p class="text-muted lead">No products found.</p>
        <a href="/shop" class="btn btn-outline-secondary">View All Products</a>
      </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
