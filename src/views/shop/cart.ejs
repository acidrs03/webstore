<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<div class="container py-4">
  <h1 class="h3 mb-4">Your Cart</h1>

  <% if (cart.items && cart.items.length > 0) { %>
  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
          <% cart.items.forEach(function(item, i) { %>
          <div class="cart-item d-flex gap-3 p-3 <%= i < cart.items.length - 1 ? 'border-bottom' : '' %>">
            <!-- Image -->
            <div class="cart-item-img flex-shrink-0">
              <% if (item.image) { %>
                <img src="<%= item.image %>" alt="<%= item.title %>" class="rounded" style="width:80px;height:80px;object-fit:cover;">
              <% } else { %>
                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width:80px;height:80px;">
                  <span class="text-muted small">No img</span>
                </div>
              <% } %>
            </div>

            <!-- Details -->
            <div class="flex-grow-1">
              <h6 class="mb-1">
                <a href="/shop/<%= item.slug %>" class="text-dark text-decoration-none"><%= item.title %></a>
              </h6>
              <% if (item.customizationText) { %>
                <p class="small text-muted mb-1">Personalization: <em><%= item.customizationText %></em></p>
              <% } %>
              <div class="d-flex align-items-center gap-3 mt-2">
                <!-- Quantity update form -->
                <form action="/cart/update" method="POST" class="d-flex align-items-center gap-2">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="index" value="<%= i %>">
                  <input type="number" name="quantity" value="<%= item.quantity %>" min="0" max="99"
                         class="form-control form-control-sm text-center" style="width:65px">
                  <button type="submit" class="btn btn-sm btn-outline-secondary">Update</button>
                </form>
                <!-- Remove -->
                <form action="/cart/remove" method="POST">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="index" value="<%= i %>">
                  <button type="submit" class="btn btn-sm btn-link text-danger p-0">Remove</button>
                </form>
              </div>
            </div>

            <!-- Price -->
            <div class="text-end flex-shrink-0">
              <span class="fw-semibold">$<%= ((item.price * item.quantity) / 100).toFixed(2) %></span>
              <div class="small text-muted">$<%= (item.price / 100).toFixed(2) %> ea.</div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>

      <!-- Clear cart -->
      <form action="/cart/clear" method="POST" class="mt-2">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-sm btn-link text-muted">Clear Cart</button>
      </form>
    </div>

    <!-- Summary -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h5 class="card-title mb-3">Order Summary</h5>
          <div class="d-flex justify-content-between mb-2">
            <span>Subtotal</span>
            <span class="fw-semibold">$<%= (cart.subtotal / 100).toFixed(2) %></span>
          </div>
          <div class="d-flex justify-content-between mb-3 text-muted small">
            <span>Shipping & taxes</span>
            <span>Calculated at checkout</span>
          </div>
          <hr>
          <form action="/checkout/session" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-primary-custom w-100 btn-lg">
              Proceed to Checkout
            </button>
          </form>
          <a href="/shop" class="btn btn-link w-100 text-muted mt-2">Continue Shopping</a>
        </div>
      </div>
    </div>
  </div>

  <% } else { %>
  <div class="text-center py-5">
    <div class="display-1 mb-3">🛒</div>
    <h4 class="text-muted">Your cart is empty</h4>
    <p class="text-muted">Looks like you haven't added anything yet.</p>
    <a href="/shop" class="btn btn-primary-custom mt-2">Start Shopping</a>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
</body>
</html>
