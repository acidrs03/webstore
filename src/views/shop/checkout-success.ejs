<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/nav') %>

<div class="container py-5 text-center">
  <div class="mx-auto" style="max-width:560px">
    <div class="display-1 text-success mb-3">✓</div>
    <h1 class="h2 mb-3">Order Confirmed!</h1>
    <p class="lead text-muted mb-4">Thank you for your purchase! You'll receive a confirmation email shortly.</p>

    <% if (order) { %>
    <div class="card border-0 shadow-sm mb-4 text-start">
      <div class="card-body">
        <h5 class="card-title">Order #<%= order.orderNumber %></h5>
        <p class="text-muted small mb-3">Placed on <%= order.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>

        <% if (order.items && order.items.length > 0) { %>
        <div class="mb-3">
          <% order.items.forEach(function(item) { %>
          <div class="d-flex justify-content-between py-1 border-bottom small">
            <span><%= item.title %> × <%= item.quantity %></span>
            <span>$<%= ((item.price * item.quantity) / 100).toFixed(2) %></span>
          </div>
          <% }); %>
        </div>
        <% } %>

        <div class="d-flex justify-content-between fw-semibold">
          <span>Total</span>
          <span>$<%= (order.total / 100).toFixed(2) %></span>
        </div>
      </div>
    </div>
    <% } %>

    <div class="d-flex gap-3 justify-content-center">
      <a href="/shop" class="btn btn-primary-custom">Continue Shopping</a>
      <a href="/contact" class="btn btn-outline-secondary">Contact Us</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
