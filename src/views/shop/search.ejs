<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<div class="container py-4">
  <!-- Search Form -->
  <form method="GET" action="/shop/search" class="mb-4">
    <div class="input-group input-group-lg" style="max-width:500px">
      <input type="text" name="q" class="form-control" placeholder="Search products…" value="<%= query || '' %>">
      <button class="btn btn-primary-custom" type="submit">Search</button>
    </div>
  </form>

  <% if (query) { %>
    <h2 class="h4 mb-4">
      Results for "<%= query %>"
      <span class="text-muted fw-normal fs-6">(<%= products.length %> found)</span>
    </h2>
  <% } %>

  <% if (products && products.length > 0) { %>
  <div class="row g-4">
    <% products.forEach(function(product) { %>
    <div class="col-6 col-md-4 col-lg-3">
      <div class="product-card card h-100 border-0 shadow-sm">
        <a href="/shop/<%= product.slug %>" class="product-card-img-link">
          <div class="product-img-wrapper">
            <% if (product.images && product.images[0]) { %>
              <img src="<%= product.images[0] %>" alt="<%= product.title %>" class="product-img card-img-top">
            <% } else { %>
              <div class="product-img-placeholder bg-light d-flex align-items-center justify-content-center">
                <span class="text-muted small">No Image</span>
              </div>
            <% } %>
          </div>
        </a>
        <div class="card-body">
          <h6 class="card-title small"><a href="/shop/<%= product.slug %>" class="text-dark text-decoration-none"><%= product.title %></a></h6>
          <span class="fw-semibold small">$<%= (product.price / 100).toFixed(2) %></span>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
  <% } else if (query) { %>
  <div class="text-center py-5">
    <p class="text-muted lead">No products found for "<%= query %>".</p>
    <a href="/shop" class="btn btn-outline-secondary">Browse All Products</a>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
</body>
</html>
