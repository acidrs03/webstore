<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <h1 class="h2 mb-1">Request a Custom Order</h1>
      <p class="text-muted mb-4">
        Have something special in mind? We love creating one-of-a-kind pieces.
        Fill out this form and we'll get back to you with details and pricing within 1–2 business days.
      </p>

      <form action="/custom-request" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="mb-3">
          <label for="name" class="form-label">Your Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="name" name="name" required maxlength="100">
        </div>

        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
            <input type="email" class="form-control" id="email" name="email" required>
          </div>
          <div class="col-md-6">
            <label for="phone" class="form-label">Phone <span class="text-muted small">(optional)</span></label>
            <input type="tel" class="form-control" id="phone" name="phone" maxlength="30">
          </div>
        </div>

        <div class="mb-3">
          <label for="productInterest" class="form-label">Product Type / Interest <span class="text-muted small">(optional)</span></label>
          <input type="text" class="form-control" id="productInterest" name="productInterest"
                 placeholder="e.g., Laser engraved cutting board, personalized sign…" maxlength="200">
        </div>

        <div class="mb-3">
          <label for="details" class="form-label">Tell us about your request <span class="text-danger">*</span></label>
          <textarea class="form-control" id="details" name="details" rows="6" required maxlength="2000"
                    placeholder="Please describe what you have in mind: size, material, text to engrave, quantity, any special requirements…"></textarea>
          <div class="form-text">The more detail you provide, the more accurately we can quote you.</div>
        </div>

        <div class="mb-4">
          <label for="referenceImage" class="form-label">Reference Image <span class="text-muted small">(optional)</span></label>
          <input type="file" class="form-control" id="referenceImage" name="referenceImage"
                 accept="image/jpeg,image/png,image/webp,image/gif">
          <div class="form-text">Upload an inspiration photo or sketch if you have one. Max 10MB.</div>
        </div>

        <button type="submit" class="btn btn-primary-custom btn-lg px-4">Submit Request</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
