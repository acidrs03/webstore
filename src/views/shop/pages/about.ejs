<!DOCTYPE html>
<html lang="en">
<head><%- include('../../partials/head') %></head>
<body>
<%- include('../../partials/nav') %>
<%- include('../../partials/flash') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <h1 class="h2 mb-4"><%= content.title || 'About Us' %></h1>
      <% if (content.body) { %>
        <div class="page-content"><%- content.body %></div>
      <% } else { %>
        <div class="page-content">
          <p class="lead">Welcome to <%= siteName %> — where every item is made with intention and care.</p>
          <p>We're a small, passionate business specializing in handcrafted and personalized items. From custom gifts to unique keepsakes, we pour our heart into each piece we create.</p>
          <p>Every order is made with care. We believe in quality over quantity, and in creating items that last a lifetime.</p>
          <p>Have a special idea? We'd love to bring it to life. <a href="/custom-request">Send us a custom order request</a> and let's create something together.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
</body>
</html>
