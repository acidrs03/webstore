<!DOCTYPE html>
<html lang="en">
<head><%- include('../../partials/admin/head') %></head>
<body>
<div class="admin-wrapper">
  <%- include('../../partials/admin/sidebar') %>
  <main class="admin-main">
    <div class="admin-topbar">
      <h4 class="mb-0"><%= title %></h4>
    </div>
    <div class="admin-content">
      <%- include('../../partials/flash') %>

      <div class="card border-0 shadow-sm" style="max-width: 640px;">
        <div class="card-body p-4">
          <form action="<%= isNew ? '/admin/shipping' : '/admin/shipping/' + method._id %>" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="mb-3">
              <label for="name" class="form-label">Method Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="name" name="name"
                value="<%= method.name || '' %>" required placeholder="e.g. Standard Shipping">
            </div>

            <div class="mb-3">
              <label for="description" class="form-label">Description</label>
              <input type="text" class="form-control" id="description" name="description"
                value="<%= method.description || '' %>" placeholder="e.g. Delivered via USPS First Class">
              <div class="form-text">Shown to customers at checkout (optional).</div>
            </div>

            <div class="mb-3">
              <label for="price" class="form-label">Price <span class="text-danger">*</span></label>
              <div class="input-group" style="max-width: 180px;">
                <span class="input-group-text">$</span>
                <input type="number" class="form-control" id="price" name="price"
                  value="<%= typeof method.price !== 'undefined' ? (method.price / 100).toFixed(2) : '0.00' %>"
                  min="0" step="0.01" required>
              </div>
              <div class="form-text">Enter 0.00 for free shipping.</div>
            </div>

            <div class="mb-3">
              <label class="form-label">Estimated Delivery (Business Days)</label>
              <div class="d-flex align-items-center gap-2" style="max-width: 280px;">
                <input type="number" class="form-control" name="estimatedMin"
                  value="<%= method.estimatedMin !== undefined ? method.estimatedMin : 3 %>"
                  min="0" placeholder="Min">
                <span class="text-muted">to</span>
                <input type="number" class="form-control" name="estimatedMax"
                  value="<%= method.estimatedMax !== undefined ? method.estimatedMax : 7 %>"
                  min="0" placeholder="Max">
              </div>
            </div>

            <div class="mb-3">
              <label for="sortOrder" class="form-label">Sort Order</label>
              <input type="number" class="form-control" id="sortOrder" name="sortOrder"
                value="<%= method.sortOrder || 0 %>" style="max-width: 120px;">
              <div class="form-text">Lower numbers appear first at checkout.</div>
            </div>

            <div class="mb-4">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="isActive" name="isActive"
                  <%= (!method._id || method.isActive) ? 'checked' : '' %>>
                <label class="form-check-label" for="isActive">Active</label>
              </div>
              <div class="form-text">Only active methods are shown at checkout.</div>
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-dark"><%= isNew ? 'Create Method' : 'Save Changes' %></button>
              <a href="/admin/shipping" class="btn btn-outline-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>

    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
