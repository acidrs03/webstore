<!DOCTYPE html>
<html lang="en">
<head><%- include('../../partials/admin/head') %></head>
<body>
<div class="admin-wrapper">
  <%- include('../../partials/admin/sidebar') %>
  <main class="admin-main">
    <div class="admin-topbar d-flex justify-content-between align-items-center">
      <h4 class="mb-0">Shipping Methods</h4>
      <a href="/admin/shipping/new" class="btn btn-dark btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Add Method
      </a>
    </div>
    <div class="admin-content">
      <%- include('../../partials/flash') %>

      <!-- Free Shipping Rule -->
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3">
          <h6 class="mb-0 fw-semibold"><i class="bi bi-gift me-2"></i>Free Shipping Rule</h6>
        </div>
        <div class="card-body">
          <form action="/admin/shipping/free-shipping/save" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="row g-3 align-items-end">
              <div class="col-md-3">
                <div class="form-check form-switch mt-2">
                  <input class="form-check-input" type="checkbox" id="freeShippingEnabled" name="freeShippingEnabled"
                    <%= settingsMap.freeShippingEnabled === 'true' ? 'checked' : '' %>>
                  <label class="form-check-label" for="freeShippingEnabled">Enable Free Shipping</label>
                </div>
              </div>
              <div class="col-md-3">
                <label for="freeShippingThreshold" class="form-label">Order Minimum ($)</label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" class="form-control" id="freeShippingThreshold" name="freeShippingThreshold"
                    min="0" step="0.01"
                    value="<%= settingsMap.freeShippingThreshold || '0' %>">
                </div>
                <div class="form-text">Orders at or above this amount qualify for free shipping.</div>
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-dark">Save</button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <!-- Shipping Methods List -->
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
          <h6 class="mb-0 fw-semibold"><i class="bi bi-truck me-2"></i>Shipping Methods</h6>
        </div>
        <% if (methods.length === 0) { %>
        <div class="card-body">
          <p class="text-muted mb-0">No shipping methods yet. <a href="/admin/shipping/new">Add one</a> to offer shipping options at checkout.</p>
        </div>
        <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Est. Delivery</th>
                <th>Sort</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% methods.forEach(function(m) { %>
              <tr>
                <td class="fw-medium"><%= m.name %></td>
                <td class="text-muted small"><%= m.description || '—' %></td>
                <td>
                  <% if (m.price === 0) { %>
                    <span class="text-success fw-medium">Free</span>
                  <% } else { %>
                    $<%= (m.price / 100).toFixed(2) %>
                  <% } %>
                </td>
                <td class="small"><%= m.estimatedMin %>–<%= m.estimatedMax %> business days</td>
                <td><%= m.sortOrder %></td>
                <td>
                  <% if (m.isActive) { %>
                    <span class="badge bg-success-subtle text-success">Active</span>
                  <% } else { %>
                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                  <% } %>
                </td>
                <td class="text-end">
                  <a href="/admin/shipping/<%= m._id %>/edit" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                  <form action="/admin/shipping/<%= m._id %>/delete" method="POST" class="d-inline"
                    onsubmit="return confirm('Delete this shipping method?')">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
