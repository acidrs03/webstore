<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/admin/head') %></head>
<body>
<div class="admin-wrapper">
  <%- include('../partials/admin/sidebar') %>
  <main class="admin-main">
    <div class="admin-topbar">
      <h4 class="mb-0">Dashboard</h4>
      <span class="text-muted small">Welcome back, <%= adminUser ? adminUser.name : 'Admin' %>!</span>
    </div>
    <div class="admin-content">
      <%- include('../partials/flash') %>

      <!-- Stat Cards -->
      <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
          <div class="stat-card card border-0 shadow-sm stat-blue">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="stat-label text-muted small text-uppercase fw-semibold">Total Orders</div>
                  <div class="stat-value h3 fw-bold mb-0"><%= orderStats.totalOrders || 0 %></div>
                </div>
                <i class="bi bi-bag-check stat-icon text-muted"></i>
              </div>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-3">
          <div class="stat-card card border-0 shadow-sm stat-green">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="stat-label text-muted small text-uppercase fw-semibold">Total Revenue</div>
                  <div class="stat-value h3 fw-bold mb-0">$<%= ((orderStats.totalRevenue || 0) / 100).toFixed(2) %></div>
                </div>
                <i class="bi bi-currency-dollar stat-icon text-muted"></i>
              </div>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-3">
          <div class="stat-card card border-0 shadow-sm stat-yellow">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="stat-label text-muted small text-uppercase fw-semibold">Pending Orders</div>
                  <div class="stat-value h3 fw-bold mb-0"><%= orderStats.pendingOrders || 0 %></div>
                </div>
                <i class="bi bi-clock stat-icon text-muted"></i>
              </div>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-3">
          <div class="stat-card card border-0 shadow-sm stat-red">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="stat-label text-muted small text-uppercase fw-semibold">New Requests</div>
                  <div class="stat-value h3 fw-bold mb-0"><%= requestStats.new || 0 %></div>
                </div>
                <i class="bi bi-pencil-square stat-icon text-muted"></i>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Orders -->
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
          <h6 class="mb-0 fw-semibold">Recent Orders</h6>
          <a href="/admin/orders" class="btn btn-sm btn-outline-secondary">View All</a>
        </div>
        <div class="table-responsive">
          <table class="table table-hover mb-0 admin-table">
            <thead class="table-light">
              <tr>
                <th>Order #</th>
                <th>Customer</th>
                <th>Total</th>
                <th>Payment</th>
                <th>Fulfillment</th>
                <th>Date</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% if (recentOrders && recentOrders.length > 0) { %>
                <% recentOrders.forEach(function(order) { %>
                <tr>
                  <td><code><%= order.orderNumber %></code></td>
                  <td><%= order.customer.name || order.customer.email %></td>
                  <td>$<%= (order.total / 100).toFixed(2) %></td>
                  <td>
                    <span class="badge <%= order.paymentStatus === 'paid' ? 'bg-success' : order.paymentStatus === 'pending' ? 'bg-warning text-dark' : 'bg-danger' %>">
                      <%= order.paymentStatus %>
                    </span>
                  </td>
                  <td>
                    <span class="badge bg-secondary"><%= order.fulfillmentStatus %></span>
                  </td>
                  <td class="text-muted small"><%= order.createdAt.toLocaleDateString() %></td>
                  <td><a href="/admin/orders/<%= order._id %>" class="btn btn-sm btn-outline-secondary">View</a></td>
                </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="7" class="text-center text-muted py-4">No orders yet.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/admin.js"></script>
</body>
</html>
