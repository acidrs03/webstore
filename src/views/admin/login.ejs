<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — <%= typeof siteName !== 'undefined' ? siteName : 'My Store' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    body { background: #f0f0f0; min-height: 100vh; display: flex; align-items: center; }
  </style>
</head>
<body>
<div class="container">
  <div class="row justify-content-center">
    <div class="col-sm-8 col-md-5 col-lg-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <div class="text-center mb-4">
            <h1 class="h4 fw-bold mb-1"><%= typeof siteName !== 'undefined' ? siteName : 'My Store' %></h1>
            <p class="text-muted small">Admin Panel</p>
          </div>

          <% if (typeof error !== 'undefined' && error && error.length) { %>
            <% error.forEach(function(msg) { %>
              <div class="alert alert-danger py-2 small"><%= msg %></div>
            <% }); %>
          <% } %>
          <% if (typeof success !== 'undefined' && success && success.length) { %>
            <% success.forEach(function(msg) { %>
              <div class="alert alert-success py-2 small"><%= msg %></div>
            <% }); %>
          <% } %>

          <form action="/admin/login" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="mb-3">
              <label for="email" class="form-label">Email address</label>
              <input type="email" class="form-control" id="email" name="email" required autofocus autocomplete="username">
            </div>
            <div class="mb-4">
              <label for="password" class="form-label">Password</label>
              <input type="password" class="form-control" id="password" name="password" required autocomplete="current-password">
            </div>
            <button type="submit" class="btn btn-dark w-100">Log In</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
