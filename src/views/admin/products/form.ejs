<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../partials/admin/head') %>
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
  <style>
    .ql-container { font-size: 0.95rem; }
    .ql-editor { min-height: 180px; max-height: 500px; overflow-y: auto; }
    .ql-toolbar.ql-snow { border-radius: 0.375rem 0.375rem 0 0; border-color: #dee2e6; background: #f8f9fa; }
    .ql-container.ql-snow { border-radius: 0 0 0.375rem 0.375rem; border-color: #dee2e6; }
  </style>
</head>
<body>
<div class="admin-wrapper">
  <%- include('../../partials/admin/sidebar') %>
  <main class="admin-main">
    <div class="admin-topbar">
      <h4 class="mb-0"><%= isNew ? 'New Product' : 'Edit Product' %></h4>
      <a href="/admin/products" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Products
      </a>
    </div>
    <div class="admin-content">
      <%- include('../../partials/flash') %>

      <form action="<%= isNew ? '/admin/products' : '/admin/products/' + product._id %>" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="row g-4">
          <!-- Left column (main content) -->
          <div class="col-lg-8">

            <!-- Basic Info -->
            <div class="card border-0 shadow-sm mb-4">
              <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Basic Information</h6>
              </div>
              <div class="card-body">
                <div class="mb-3">
                  <label for="title" class="form-label">Product Title <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="title" name="title" value="<%= product.title || '' %>" required maxlength="200">
                </div>
                <div class="mb-3">
                  <label for="slug" class="form-label">URL Slug</label>
                  <div class="input-group">
                    <span class="input-group-text text-muted">/shop/</span>
                    <input type="text" class="form-control" id="slug" name="slug" value="<%= product.slug || '' %>" pattern="[a-z0-9\-]+" placeholder="auto-generated">
                  </div>
                  <div class="form-text">Auto-generated from title. Only lowercase letters, numbers, and hyphens.</div>
                </div>
                <div class="mb-3">
                  <label for="shortDescription" class="form-label">Short Description</label>
                  <input type="text" class="form-control" id="shortDescription" name="shortDescription" value="<%= product.shortDescription || '' %>" maxlength="500" placeholder="Brief product summary (appears in listings)">
                  <div class="form-text">Max 500 characters. Shown on product cards and listings.</div>
                </div>
                <div class="mb-0">
                  <div class="d-flex justify-content-between align-items-center mb-1">
                    <label class="form-label mb-0">Full Description</label>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="toggleSource">
                      <i class="bi bi-code-slash me-1"></i> Source
                    </button>
                  </div>
                  <div id="quillEditor"></div>
                  <textarea id="sourceEditor" class="form-control font-monospace small d-none" rows="10" spellcheck="false"></textarea>
                  <textarea id="description" name="description" style="display:none"></textarea>
                </div>
              </div>
            </div>

            <!-- Pricing -->
            <div class="card border-0 shadow-sm mb-4">
              <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Pricing</h6>
              </div>
              <div class="card-body">
                <div class="row g-3">
                  <div class="col-md-4">
                    <label for="price" class="form-label">Price <span class="text-danger">*</span></label>
                    <div class="input-group">
                      <span class="input-group-text">$</span>
                      <input type="number" class="form-control" id="price" name="price" value="<%= product.price ? (product.price / 100).toFixed(2) : '' %>" step="0.01" min="0" required>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <label for="compareAtPrice" class="form-label">Compare-at Price</label>
                    <div class="input-group">
                      <span class="input-group-text">$</span>
                      <input type="number" class="form-control" id="compareAtPrice" name="compareAtPrice" value="<%= product.compareAtPrice ? (product.compareAtPrice / 100).toFixed(2) : '' %>" step="0.01" min="0" placeholder="0.00">
                    </div>
                    <div class="form-text">Original price for sale display. Leave blank if not on sale.</div>
                  </div>
                  <div class="col-md-4">
                    <label for="sku" class="form-label">SKU</label>
                    <input type="text" class="form-control" id="sku" name="sku" value="<%= product.sku || '' %>" maxlength="100" placeholder="e.g. ITEM-001">
                    <div class="form-text">Your internal product code.</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Images -->
            <div class="card border-0 shadow-sm mb-4">
              <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Images</h6>
              </div>
              <div class="card-body">
                <% if (!isNew && product.images && product.images.length > 0) { %>
                <div class="mb-3">
                  <label class="form-label small text-muted">Current Images</label>
                  <div class="d-flex gap-2 flex-wrap">
                    <% product.images.forEach(function(img) { %>
                    <div class="position-relative">
                      <img src="<%= img %>" class="rounded border" style="width:80px;height:80px;object-fit:cover;" alt="Product image">
                      <label class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end justify-content-center pb-1" style="cursor:pointer;background:rgba(0,0,0,0.3);border-radius:4px;opacity:0;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0">
                        <input type="checkbox" name="removeImages" value="<%= img %>" class="form-check-input me-1" style="display:none">
                        <span class="badge bg-danger small" onclick="this.previousElementSibling.checked=true;this.closest('.position-relative').style.opacity=0.3">Remove</span>
                      </label>
                    </div>
                    <% }); %>
                  </div>
                  <div class="form-text">Hover over an image and click Remove to delete it.</div>
                </div>
                <% } %>
                <div>
                  <label for="images" class="form-label">Upload Images</label>
                  <input type="file" class="form-control" id="images" name="images" multiple accept="image/jpeg,image/png,image/webp">
                  <div class="form-text">Select up to 8 images. JPEG, PNG, WebP. Max 10MB each. First image is used as the main product image.</div>
                </div>
              </div>
            </div>

            <!-- Customization -->
            <div class="card border-0 shadow-sm mb-4">
              <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Personalization</h6>
              </div>
              <div class="card-body">
                <div class="form-check form-switch mb-3">
                  <input class="form-check-input" type="checkbox" id="allowsCustomization" name="allowsCustomization" value="on" <%= product.allowsCustomization ? 'checked' : '' %>>
                  <label class="form-check-label" for="allowsCustomization">Allow customers to add personalization text</label>
                </div>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label for="customizationLabel" class="form-label">Personalization Field Label</label>
                    <input type="text" class="form-control" id="customizationLabel" name="customizationLabel" value="<%= product.customizationLabel || 'Personalization' %>" maxlength="100">
                    <div class="form-text">e.g., "Name to Engrave", "Custom Message"</div>
                  </div>
                  <div class="col-md-6">
                    <label for="leadTimeDays" class="form-label">Lead Time (days)</label>
                    <input type="number" class="form-control" id="leadTimeDays" name="leadTimeDays" value="<%= product.leadTimeDays || 0 %>" min="0">
                    <div class="form-text">Extra production days shown to customers.</div>
                  </div>
                  <div class="col-12">
                    <label for="customizationHelpText" class="form-label">Help Text / Instructions</label>
                    <input type="text" class="form-control" id="customizationHelpText" name="customizationHelpText" value="<%= product.customizationHelpText || '' %>" maxlength="300" placeholder="e.g., 'Enter up to 20 characters. No special symbols.'">
                  </div>
                </div>
              </div>
            </div>

            <!-- SEO -->
            <div class="card border-0 shadow-sm mb-4">
              <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">SEO</h6>
              </div>
              <div class="card-body">
                <div class="mb-3">
                  <label for="seoTitle" class="form-label">SEO Title</label>
                  <input type="text" class="form-control" id="seoTitle" name="seoTitle" value="<%= product.seoTitle || '' %>" maxlength="70" placeholder="Leave blank to use product title">
                </div>
                <div class="mb-0">
                  <label for="seoDescription" class="form-label">SEO Description</label>
                  <textarea class="form-control" id="seoDescription" name="seoDescription" rows="2" maxlength="160" placeholder="Leave blank to use short description"><%= product.seoDescription || '' %></textarea>
                </div>
              </div>
            </div>

          </div>

          <!-- Right column (settings) -->
          <div class="col-lg-4">

            <!-- Status -->
            <div class="card border-0 shadow-sm mb-4">
              <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Status</h6>
              </div>
              <div class="card-body">
                <div class="form-check form-switch mb-2">
                  <input class="form-check-input" type="checkbox" id="isActive" name="isActive" value="on" <%= (!isNew && product.isActive !== false) || isNew ? 'checked' : '' %>>
                  <label class="form-check-label" for="isActive">Active (visible in store)</label>
                </div>
                <div class="form-check form-switch mb-2">
                  <input class="form-check-input" type="checkbox" id="isFeatured" name="isFeatured" value="on" <%= product.isFeatured ? 'checked' : '' %>>
                  <label class="form-check-label" for="isFeatured">Featured on homepage</label>
                </div>
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="madeToOrder" name="madeToOrder" value="on" <%= product.madeToOrder ? 'checked' : '' %>>
                  <label class="form-check-label" for="madeToOrder">Made to Order</label>
                </div>
              </div>
            </div>

            <!-- Category & Tags -->
            <div class="card border-0 shadow-sm mb-4">
              <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Category & Tags</h6>
              </div>
              <div class="card-body">
                <div class="mb-3">
                  <label for="categoryId" class="form-label">Category</label>
                  <select class="form-select" id="categoryId" name="categoryId">
                    <option value="">No Category</option>
                    <% categories.forEach(function(cat) { %>
                      <option value="<%= cat._id %>" <%= product.categoryId && product.categoryId.toString() === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
                    <% }); %>
                  </select>
                </div>
                <div>
                  <label for="tags" class="form-label">Tags</label>
                  <input type="text" class="form-control" id="tags" name="tags" value="<%= product.tags ? product.tags.join(', ') : '' %>" placeholder="tag1, tag2, tag3">
                  <div class="form-text">Comma-separated list of tags.</div>
                </div>
              </div>
            </div>

            <!-- Inventory -->
            <div class="card border-0 shadow-sm mb-4">
              <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Inventory</h6>
              </div>
              <div class="card-body">
                <div class="form-check form-switch mb-3">
                  <input class="form-check-input" type="checkbox" id="trackInventory" name="trackInventory" value="on" <%= product.trackInventory ? 'checked' : '' %>>
                  <label class="form-check-label" for="trackInventory">Track inventory quantity</label>
                </div>
                <div>
                  <label for="inventoryQuantity" class="form-label">Quantity in Stock</label>
                  <input type="number" class="form-control" id="inventoryQuantity" name="inventoryQuantity" value="<%= product.inventoryQuantity || 0 %>" min="0">
                </div>
              </div>
            </div>

            <!-- Save Button -->
            <button type="submit" class="btn btn-dark w-100 btn-lg mb-2">
              <i class="bi bi-check2 me-1"></i> Save Product
            </button>
            <a href="/admin/products" class="btn btn-outline-secondary w-100">Cancel</a>

          </div>
        </div>
      </form>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script>
(function () {
  const initialHtml = <%- JSON.stringify(product.description || '') %>;
  let sourceMode = false;

  const quill = new Quill('#quillEditor', {
    theme: 'snow',
    modules: {
      toolbar: [
        [{ header: [2, 3, 4, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['blockquote', 'link'],
        [{ align: [] }],
        ['clean'],
      ],
    },
  });

  const descriptionEl = document.getElementById('description');

  function syncToField() {
    descriptionEl.value = quill.root.innerHTML;
  }

  // Load existing content and seed the hidden field
  if (initialHtml) {
    quill.clipboard.dangerouslyPasteHTML(initialHtml);
  }
  syncToField();

  // Keep the field in sync on every keystroke/format change
  quill.on('text-change', syncToField);

  const toggleBtn = document.getElementById('toggleSource');
  const sourceEl  = document.getElementById('sourceEditor');
  const editorEl  = document.getElementById('quillEditor');

  toggleBtn.addEventListener('click', function () {
    sourceMode = !sourceMode;
    if (sourceMode) {
      sourceEl.value = quill.root.innerHTML;
      editorEl.classList.add('d-none');
      sourceEl.classList.remove('d-none');
      toggleBtn.innerHTML = '<i class="bi bi-eye me-1"></i> Visual';
    } else {
      quill.clipboard.dangerouslyPasteHTML(sourceEl.value);
      sourceEl.classList.add('d-none');
      editorEl.classList.remove('d-none');
      toggleBtn.innerHTML = '<i class="bi bi-code-slash me-1"></i> Source';
      syncToField();
    }
  });

  // Final sync on submit to catch source-mode edits
  document.querySelector('form').addEventListener('submit', function () {
    descriptionEl.value = sourceMode ? sourceEl.value : quill.root.innerHTML;
  });
})();
</script>
<script src="/js/admin.js"></script>
</body>
</html>
