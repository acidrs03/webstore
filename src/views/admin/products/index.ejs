<!DOCTYPE html>
<html lang="en">
<head><%- include('../../partials/admin/head') %></head>
<body>
<div class="admin-wrapper">
  <%- include('../../partials/admin/sidebar') %>
  <main class="admin-main">
    <div class="admin-topbar">
      <h4 class="mb-0">Products</h4>
      <a href="/admin/products/new" class="btn btn-sm btn-dark">
        <i class="bi bi-plus-lg me-1"></i> Add Product
      </a>
    </div>
    <div class="admin-content">
      <%- include('../../partials/flash') %>

      <!-- Filters -->
      <form method="GET" action="/admin/products" class="card border-0 shadow-sm mb-4">
        <div class="card-body">
          <div class="row g-2 align-items-end">
            <div class="col-md-4">
              <input type="text" name="search" class="form-control form-control-sm" placeholder="Search products…" value="<%= filters.search || '' %>">
            </div>
            <div class="col-md-3">
              <select name="category" class="form-select form-select-sm">
                <option value="">All Categories</option>
                <% categories.forEach(function(cat) { %>
                  <option value="<%= cat._id %>" <%= filters.category === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-3">
              <select name="status" class="form-select form-select-sm">
                <option value="">All Products</option>
                <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
                <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                <option value="featured" <%= filters.status === 'featured' ? 'selected' : '' %>>Featured</option>
                <option value="archived" <%= filters.status === 'archived' ? 'selected' : '' %>>Archived</option>
              </select>
            </div>
            <div class="col-md-2">
              <button type="submit" class="btn btn-sm btn-outline-secondary w-100">Filter</button>
            </div>
          </div>
        </div>
      </form>

      <div class="card border-0 shadow-sm">
        <div class="table-responsive">
          <table class="table table-hover mb-0 admin-table">
            <thead class="table-light">
              <tr>
                <th style="width:60px">Image</th>
                <th>Title</th>
                <th>SKU</th>
                <th>Price</th>
                <th>Category</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (products && products.length > 0) { %>
                <% products.forEach(function(product) { %>
                <tr>
                  <td>
                    <% if (product.images && product.images[0]) { %>
                      <img src="<%= product.images[0] %>" alt="" class="rounded" style="width:48px;height:48px;object-fit:cover;">
                    <% } else { %>
                      <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                        <i class="bi bi-image text-muted"></i>
                      </div>
                    <% } %>
                  </td>
                  <td>
                    <a href="/admin/products/<%= product._id %>/edit" class="fw-semibold text-dark text-decoration-none"><%= product.title %></a>
                    <% if (product.isArchived) { %>
                      <span class="badge bg-secondary ms-1">Archived</span>
                    <% } %>
                  </td>
                  <td class="text-muted small"><%= product.sku || '—' %></td>
                  <td>$<%= (product.price / 100).toFixed(2) %></td>
                  <td class="text-muted small"><%= product.categoryId ? product.categoryId.name : '—' %></td>
                  <td>
                    <% if (!product.isArchived) { %>
                      <span class="badge <%= product.isActive ? 'bg-success' : 'bg-secondary' %> me-1"><%= product.isActive ? 'Active' : 'Inactive' %></span>
                      <% if (product.isFeatured) { %><span class="badge bg-warning text-dark">Featured</span><% } %>
                    <% } %>
                  </td>
                  <td>
                    <div class="d-flex gap-1 flex-wrap">
                      <a href="/admin/products/<%= product._id %>/edit" class="btn btn-xs btn-outline-secondary" title="Edit">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <a href="/shop/<%= product.slug %>" target="_blank" class="btn btn-xs btn-outline-secondary" title="Preview">
                        <i class="bi bi-eye"></i>
                      </a>
                      <% if (!product.isArchived) { %>
                        <form action="/admin/products/<%= product._id %>/toggle-active" method="POST" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-xs btn-outline-<%= product.isActive ? 'warning' : 'success' %>" title="<%= product.isActive ? 'Deactivate' : 'Activate' %>">
                            <i class="bi bi-<%= product.isActive ? 'toggle-on' : 'toggle-off' %>"></i>
                          </button>
                        </form>
                        <form action="/admin/products/<%= product._id %>/toggle-featured" method="POST" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-xs btn-outline-<%= product.isFeatured ? 'warning' : 'secondary' %>" title="<%= product.isFeatured ? 'Unfeature' : 'Feature' %>">
                            <i class="bi bi-star<%= product.isFeatured ? '-fill' : '' %>"></i>
                          </button>
                        </form>
                        <form action="/admin/products/<%= product._id %>/duplicate" method="POST" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-xs btn-outline-secondary" title="Duplicate">
                            <i class="bi bi-copy"></i>
                          </button>
                        </form>
                        <form action="/admin/products/<%= product._id %>/archive" method="POST" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-xs btn-outline-danger" title="Archive"
                                  data-confirm="Archive '<%= product.title %>'? It will be hidden from the store.">
                            <i class="bi bi-archive"></i>
                          </button>
                        </form>
                      <% } else { %>
                        <form action="/admin/products/<%= product._id %>/delete" method="POST" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-xs btn-danger" title="Delete permanently"
                                  data-confirm="Permanently delete '<%= product.title %>'? This cannot be undone.">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="7" class="text-center text-muted py-5">No products found. <a href="/admin/products/new">Add your first product</a>.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if (pagination && pagination.totalPages > 1) { %>
        <div class="card-footer bg-white">
          <nav>
            <ul class="pagination pagination-sm justify-content-center mb-0">
              <% if (pagination.hasPrev) { %>
                <li class="page-item"><a class="page-link" href="?page=<%= pagination.prevPage %>&status=<%= filters.status || '' %>&search=<%= filters.search || '' %>">Previous</a></li>
              <% } %>
              <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                <li class="page-item <%= pagination.currentPage === i ? 'active' : '' %>">
                  <a class="page-link" href="?page=<%= i %>&status=<%= filters.status || '' %>&search=<%= filters.search || '' %>"><%= i %></a>
                </li>
              <% } %>
              <% if (pagination.hasNext) { %>
                <li class="page-item"><a class="page-link" href="?page=<%= pagination.nextPage %>&status=<%= filters.status || '' %>&search=<%= filters.search || '' %>">Next</a></li>
              <% } %>
            </ul>
          </nav>
        </div>
        <% } %>
      </div>

    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/admin.js"></script>
</body>
</html>
