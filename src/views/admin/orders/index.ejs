<!DOCTYPE html>
<html lang="en">
<head><%- include('../../partials/admin/head') %></head>
<body>
<div class="admin-wrapper">
  <%- include('../../partials/admin/sidebar') %>
  <main class="admin-main">
    <div class="admin-topbar">
      <h4 class="mb-0">Orders</h4>
    </div>
    <div class="admin-content">
      <%- include('../../partials/flash') %>

      <!-- Filters -->
      <form method="GET" class="card border-0 shadow-sm mb-4">
        <div class="card-body">
          <div class="row g-2 align-items-end">
            <div class="col-md-3">
              <select name="paymentStatus" class="form-select form-select-sm">
                <option value="">All Payments</option>
                <option value="pending" <%= filters.paymentStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="paid" <%= filters.paymentStatus === 'paid' ? 'selected' : '' %>>Paid</option>
                <option value="failed" <%= filters.paymentStatus === 'failed' ? 'selected' : '' %>>Failed</option>
                <option value="refunded" <%= filters.paymentStatus === 'refunded' ? 'selected' : '' %>>Refunded</option>
              </select>
            </div>
            <div class="col-md-3">
              <select name="fulfillmentStatus" class="form-select form-select-sm">
                <option value="">All Fulfillment</option>
                <option value="unfulfilled" <%= filters.fulfillmentStatus === 'unfulfilled' ? 'selected' : '' %>>Unfulfilled</option>
                <option value="processing" <%= filters.fulfillmentStatus === 'processing' ? 'selected' : '' %>>Processing</option>
                <option value="shipped" <%= filters.fulfillmentStatus === 'shipped' ? 'selected' : '' %>>Shipped</option>
                <option value="delivered" <%= filters.fulfillmentStatus === 'delivered' ? 'selected' : '' %>>Delivered</option>
                <option value="cancelled" <%= filters.fulfillmentStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
              </select>
            </div>
            <div class="col-md-4">
              <input type="text" name="search" class="form-control form-control-sm" placeholder="Search order # or email…" value="<%= filters.search || '' %>">
            </div>
            <div class="col-md-2">
              <button type="submit" class="btn btn-sm btn-outline-secondary w-100">Filter</button>
            </div>
          </div>
        </div>
      </form>

      <div class="card border-0 shadow-sm">
        <div class="table-responsive">
          <table class="table table-hover mb-0 admin-table">
            <thead class="table-light">
              <tr>
                <th>Order #</th>
                <th>Customer</th>
                <th>Items</th>
                <th>Total</th>
                <th>Payment</th>
                <th>Fulfillment</th>
                <th>Date</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% if (orders && orders.length > 0) { %>
                <% orders.forEach(function(order) { %>
                <tr>
                  <td><code class="small"><%= order.orderNumber %></code></td>
                  <td>
                    <div class="fw-semibold small"><%= order.customer.name || '—' %></div>
                    <div class="text-muted small"><%= order.customer.email %></div>
                  </td>
                  <td class="text-muted small"><%= order.items ? order.items.length : 0 %> item(s)</td>
                  <td class="fw-semibold">$<%= (order.total / 100).toFixed(2) %></td>
                  <td>
                    <span class="badge <%= order.paymentStatus === 'paid' ? 'bg-success' : order.paymentStatus === 'pending' ? 'bg-warning text-dark' : 'bg-danger' %>">
                      <%= order.paymentStatus %>
                    </span>
                  </td>
                  <td>
                    <span class="badge bg-secondary"><%= order.fulfillmentStatus %></span>
                  </td>
                  <td class="text-muted small"><%= order.createdAt.toLocaleDateString() %></td>
                  <td>
                    <a href="/admin/orders/<%= order._id %>" class="btn btn-xs btn-outline-secondary">View</a>
                  </td>
                </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="8" class="text-center text-muted py-5">No orders found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <% if (pagination && pagination.totalPages > 1) { %>
        <div class="card-footer bg-white">
          <nav>
            <ul class="pagination pagination-sm justify-content-center mb-0">
              <% if (pagination.hasPrev) { %><li class="page-item"><a class="page-link" href="?page=<%= pagination.prevPage %>">Previous</a></li><% } %>
              <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                <li class="page-item <%= pagination.currentPage === i ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %>"><%= i %></a></li>
              <% } %>
              <% if (pagination.hasNext) { %><li class="page-item"><a class="page-link" href="?page=<%= pagination.nextPage %>">Next</a></li><% } %>
            </ul>
          </nav>
        </div>
        <% } %>
      </div>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/admin.js"></script>
</body>
</html>
