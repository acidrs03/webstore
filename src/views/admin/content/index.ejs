<!DOCTYPE html>
<html lang="en">
<head><%- include('../../partials/admin/head') %></head>
<body>
<div class="admin-wrapper">
  <%- include('../../partials/admin/sidebar') %>
  <main class="admin-main">
    <div class="admin-topbar">
      <h4 class="mb-0">Content Pages</h4>
    </div>
    <div class="admin-content">
      <%- include('../../partials/flash') %>

      <div class="alert alert-light border mb-4">
        <i class="bi bi-info-circle me-1"></i>
        These are the editable content pages for your store. Click Edit to update the text, images, and information on each page.
      </div>

      <div class="card border-0 shadow-sm">
        <div class="table-responsive">
          <table class="table table-hover mb-0 admin-table">
            <thead class="table-light">
              <tr>
                <th>Page</th>
                <th>Key</th>
                <th>Last Updated</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% pages.forEach(function(page) { %>
              <tr>
                <td class="fw-semibold"><%= page.label %></td>
                <td><code class="small"><%= page.key %></code></td>
                <td class="text-muted small"><%= page.updatedAt ? page.updatedAt.toLocaleDateString() : 'Never' %></td>
                <td>
                  <a href="/admin/content/<%= page.key %>/edit" class="btn btn-xs btn-outline-secondary">
                    <i class="bi bi-pencil me-1"></i> Edit
                  </a>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
