<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forbidden | <%= typeof siteName !== 'undefined' ? siteName : 'My Store' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container py-5 text-center">
    <h1 class="display-1 fw-bold text-muted">403</h1>
    <h2 class="h3 mb-3">Forbidden</h2>
    <p class="text-muted mb-4"><%= typeof message !== 'undefined' ? message : 'You do not have permission to access this page.' %></p>
    <a href="/" class="btn btn-primary">Go Home</a>
  </div>
</body>
</html>
