<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Server Error | <%= siteName || 'My Store' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <div class="container py-5 text-center">
    <h1 class="display-1 fw-bold text-muted">500</h1>
    <h2 class="h3 mb-3">Something Went Wrong</h2>
    <p class="text-muted mb-4">We hit an unexpected error. Please try again in a moment.</p>
    <a href="/" class="btn btn-primary-custom">Go Home</a>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="mt-5 text-start mx-auto" style="max-width:700px">
      <h6 class="text-danger">Error Details (development only):</h6>
      <pre class="bg-light p-3 rounded small overflow-auto"><%= error.stack || error.message %></pre>
    </div>
    <% } %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
