<% if (announcementActive && announcementText) { %>
<div class="announcement-bar">
  <%= announcementText %>
</div>
<% } %>
<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
  <div class="container">
    <a class="navbar-brand brand-name" href="/">
      <%= siteName %>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/shop' || currentPath.startsWith('/shop') ? 'active' : '' %>" href="/shop">Shop</a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/custom-request' ? 'active' : '' %>" href="/custom-request">Custom Order</a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/pages/about' ? 'active' : '' %>" href="/pages/about">About</a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/contact' ? 'active' : '' %>" href="/contact">Contact</a>
        </li>
      </ul>
      <a href="/cart" class="btn btn-outline-secondary position-relative cart-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
          <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/>
        </svg>
        <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
          <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary-custom">
            <%= cartCount %>
          </span>
        <% } %>
      </a>
    </div>
  </div>
</nav>
